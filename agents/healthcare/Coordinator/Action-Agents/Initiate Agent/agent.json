          {
            "id": "_0yrMAPp66qvjbChDLXdL",
            "data": {
              "code": "/**\n * Generate today's date based on the provided timezone\n * @param {string} timezone - The timezone string (e.g., 'America/New_York', 'Europe/London')\n * @returns {Object} Object containing various date formats\n */\nfunction getTodayByTimezone(timezone) {\n    try {\n        // Create a new Date object for current time\n        const now = new Date();\n        \n        // Get the date string in the specified timezone (simpler approach)\n        const dateString = now.toLocaleDateString(\"en-US\", { timeZone: timezone });\n        \n        // Parse the date string (format: MM/DD/YYYY)\n        const dateParts = dateString.split('/');\n        const month = dateParts[0].padStart(2, '0');\n        const day = dateParts[1].padStart(2, '0');\n        const year = dateParts[2];\n        \n        // Get weekday name\n        const weekdayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];\n        const localDate = new Date(parseInt(year), parseInt(month) - 1, parseInt(day));\n        const weekday = weekdayNames[localDate.getDay()];\n        \n        return {\n            // Standard formats\n            iso: `${year}-${month}-${day}`,\n            us: `${month}/${day}/${year}`,\n            readable: `${weekday}, ${month}/${day}/${year}`,\n            \n            // Individual components\n            year: parseInt(year),\n            month: parseInt(month),\n            day: parseInt(day),\n            weekday: weekday,\n            \n            // Timezone info\n            timezone: timezone\n        };\n        \n    } catch (error) {\n        throw new Error(`Invalid timezone: ${timezone}. Error: ${error.message}`);\n    }\n}\n\nconst timezone = \"America/Los_Angeles\"\nContext.setVariable(\"timezone\", timezone)\nconst today = getTodayByTimezone(timezone);\nContext.setVariable(\"date_of_today\", today.iso)\nContext.setVariable(\"weekday_of_today\", today.weekday)",
              "name": "set today's date"
            },
            "type": "function",
            "position": {
