          {
            "id": "CgeYc7CjjBap_WILHEs6L",
            "data": {
              "code": "Context.setVariable(\"workflow_status\", \"success\")\n\nconst appointmentListJson = Context.getVariable(\"upcoming_appointment_list\")\n\n// 1. Filter the list first to only include specific service_type_ids\nconst filteredAppointments = appointmentListJson.future_appointments.filter(appt => {\n    const serviceId = String(appt.service_type_id); // Ensure string comparison\n    return serviceId === \"2721\" || serviceId === \"11700\";\n});\n\n// 2. Map the filtered results to the desired format\nconst finalAppointmentList = filteredAppointments.map(appt => {\n    const {\n        date_time, timezone, has_service_type_id, comment, cancelled, cancellable, address, patient_instructions,\n        ...keepFields\n    } = appt;\n\n    // Format date_time as \"YYYY-MM-DD hh:mmAM/PM\"\n    let formattedDateTime = '';\n    if (date_time) {\n        const dateObj = new Date(date_time);\n        const year = dateObj.getFullYear();\n        const month = (dateObj.getMonth() + 1).toString().padStart(2, '0');\n        const day = dateObj.getDate().toString().padStart(2, '0');\n        let hour = dateObj.getHours();\n        const minute = dateObj.getMinutes().toString().padStart(2, '0');\n        const ampm = hour >= 12 ? 'PM' : 'AM';\n        hour = hour % 12 || 12;\n        const formattedHour = hour.toString().padStart(2, '0');\n        formattedDateTime = `${year}-${month}-${day} ${formattedHour}:${minute}${ampm}`;\n    }\n\n    return {\n        ...keepFields,\n        date_time: formattedDateTime\n    };\n});\n\n// 3. Save the cleaned and filtered list back to the Context\nContext.setVariable(\"upcoming_appointment_list\", finalAppointmentList);",
              "name": "Filter fields"
            },
            "type": "function",
            "position": {
              "x": 124.5,
              "y": -433.671875
            }
          },
