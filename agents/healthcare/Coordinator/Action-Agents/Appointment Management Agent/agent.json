              "code": "/**\n * Validates if an appointment can be cancelled based on its date and service type\n * @param {string} appointmentId - The ID of the appointment to validate\n * @param {Array} appointmentsList - The list of appointments to search in\n * @returns {Object} - Object with canCancel status and reason\n */\nfunction validateAppointmentCancellation(appointmentId, appointmentsList) {\n    \n    // Find the appointment by ID\n    const appointment = appointmentsList.find(apt => apt.id === appointmentId);\n    \n    // If appointment not found\n    if (!appointment) {\n        return {\n            canCancel: false,\n            reason: \"Appointment not found\"\n        };\n    }\n    \n    // Check if the appointment is scheduled for today\n    const timezone = Context.getVariable(\"timezone\");\n    const appointmentDate = new Date(appointment.date_time);\n    // Convert today's date to local timezone for proper comparison\n    const today = new Date();\n    const todayString = today.toLocaleDateString(\"en-CA\", { \n        timeZone: timezone \n    });\n    \n    // Convert both dates to YYYY-MM-DD format for comparison\n    const appointmentDateString = appointmentDate.toLocaleDateString(\"en-CA\");\n    if (todayString === appointmentDateString) {\n        return {\n            canCancel: false,\n            reason: \"Error: Appointments for today cannot be cancelled\"\n        };\n    }\n    \n    // If all checks pass, the appointment can be cancelled\n    return {\n        canCancel: true,\n        reason: \"Appointment is eligible for cancellation\"\n    };\n}\n\nconst future_appointments_list = Context.getVariable(\"upcoming_appointment_list\")\nconst appointmentId = Context.getVariable(\"appointment_id\")\nconst cancellableFlg = validateAppointmentCancellation(appointmentId, future_appointments_list)\nif (cancellableFlg.canCancel) {\n    Context.setVariable(\"cancellable_flag\", \"Yes\")\n}else{\n    Context.setVariable(\"cancellable_flag\", \"No\")\n}\nContext.setVariable(\"workflow_status\", cancellableFlg.reason)",
              "name": "check cancellation rules"
            },
