          {
            "id": "EqIkkBOxHfpX-f-eCSITs",
            "data": {
              "code": "/**\n * Extract past encounters and check for lab test or glucose test\n * Returns only the location info of the latest visit if lab/glucose test exists\n */\nfunction getLatestLabOrGlucoseTestLocation(encountersData) {\n    const encounters = encountersData.encounters || [];\n    \n    // Filter encounters for lab tests or glucose tests\n    const labOrGlucoseTests = encounters.filter(encounter => {\n        const type = encounter.type.toLowerCase();\n        return type.includes('lab') || type.includes('glucose');\n    });\n    \n    if (labOrGlucoseTests.length === 0) {\n        return {\n            hasLabOrGlucoseTest: false,\n            location_id: null,\n            location: null\n        };\n    }\n    \n    // Sort by date_time to get the latest one\n    labOrGlucoseTests.sort((a, b) => {\n        return new Date(b.date_time).getTime() - new Date(a.date_time).getTime();\n    });\n    \n    const latestTest = labOrGlucoseTests[0];\n    \n    return {\n        hasLabOrGlucoseTest: true,\n        location_id: latestTest.location_id,\n        location: latestTest.location\n    };\n}\nconst patientEncounters = Context.getVariable(\"past_encounter_list\")\nContext.setVariable(\"workflow_status\", \"\")\n// Run the function\nconst result = getLatestLabOrGlucoseTestLocation(patientEncounters);\nif (result.hasLabOrGlucoseTest) {\n    Context.setVariable(\"workflow_status\", `User has previous lab or glucose test at the location ${result.location}`)\n} else {\n   Context.setVariable(\"workflow_status\", \"User has no previous lab or glucose test\")\n}",
              "name": "Check if user has previous encounters"
            },
            "type": "function",
            "position": {
