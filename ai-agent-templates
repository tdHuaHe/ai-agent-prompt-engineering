#!/usr/bin/env bash
set -euo pipefail

DEFAULT_INDUSTRY="fsi-banking"

usage() {
  cat <<'EOF'
Usage:
  ai-agent-templates decompose [--industry <name>] [<input.json>]
  ai-agent-templates compose <env_name> [--industry <name>] [--agents "A,B,C"]

Examples:
  ai-agent-templates decompose --industry fsi-banking
  ai-agent-templates decompose "systems/fsi-banking/imports/example.json" --industry fsi-banking
  ai-agent-templates compose test --industry fsi-banking
  ai-agent-templates compose test --industry fsi-banking --agents "FAQ Agent,Member Search Agent"
EOF
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

cmd="$1"
shift

case "$cmd" in
  decompose)
    if [[ $# -lt 1 ]]; then
      usage
      exit 1
    fi

    input="$1"
    shift
    industry="$DEFAULT_INDUSTRY"

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --industry)
          [[ $# -ge 2 ]] || { echo "Missing value for --industry"; exit 1; }
          industry="$2"
          shift 2
          ;;
        -h|--help)
          usage
          exit 0
          ;;
        *)
          echo "Unknown argument: $1"
          usage
          exit 1
          ;;
      esac
    done

    exec python3 tools/split.py "$input" "$industry"
    ;;

  compose)
    if [[ $# -lt 1 ]]; then
      usage
      exit 1
    fi

    env_name="$1"
    shift
    industry="$DEFAULT_INDUSTRY"
    agents=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --industry)
          [[ $# -ge 2 ]] || { echo "Missing value for --industry"; exit 1; }
          industry="$2"
          shift 2
          ;;
        --agents)
          [[ $# -ge 2 ]] || { echo "Missing value for --agents"; exit 1; }
          agents="$2"
          shift 2
          ;;
        -h|--help)
          usage
          exit 0
          ;;
        *)
          echo "Unknown argument: $1"
          usage
          exit 1
          ;;
      esac
    done

    if [[ -n "$agents" ]]; then
      exec python3 tools/build.py "$env_name" "$agents" "$industry"
    else
      exec python3 tools/build.py "$env_name" "" "$industry"
    fi
    ;;

  -h|--help|help)
    usage
    exit 0
    ;;

  *)
    echo "Unknown command: $cmd"
    usage
    exit 1
    ;;
esac
